<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CL Contract AI - 계약서 위험 분석</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: -apple-system, BlinkMacSystemFont, 'Pretendard', sans-serif; background: #f8f8f6; color: #1a1a1a; min-height: 100vh; }

.wrap { max-width: 720px; margin: 0 auto; padding: 3rem 1.5rem; }

.logo { font-size: 11px; font-weight: 600; letter-spacing: 0.12em; color: #888; margin-bottom: 8px; }
h1 { font-size: 28px; font-weight: 700; margin-bottom: 6px; }
.sub { font-size: 15px; color: #666; margin-bottom: 2.5rem; }

.card { background: #fff; border-radius: 16px; border: 1px solid #e8e8e4; padding: 1.5rem; margin-bottom: 1rem; }

label { display: block; font-size: 12px; font-weight: 600; color: #666; margin-bottom: 8px; letter-spacing: 0.04em; }

textarea { width: 100%; height: 200px; border: 1px solid #e0e0db; border-radius: 10px; padding: 14px; font-size: 14px; font-family: inherit; color: #1a1a1a; background: #fafaf8; resize: vertical; line-height: 1.7; outline: none; }
textarea:focus { border-color: #aaa; }
textarea::placeholder { color: #bbb; }

.tier-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 1.5rem; }
.tier { border: 1.5px solid #e0e0db; border-radius: 12px; padding: 14px; cursor: pointer; transition: all 0.15s; background: #fafaf8; }
.tier:hover { border-color: #ccc; }
.tier.on { border-color: #1a1a1a; background: #fff; }
.tier-name { font-size: 14px; font-weight: 600; margin-bottom: 3px; }
.tier-price { font-size: 12px; color: #888; margin-bottom: 8px; }
.tier-desc { font-size: 11px; color: #aaa; line-height: 1.5; }

.btn { width: 100%; height: 50px; background: #1a1a1a; color: #fff; border: none; border-radius: 12px; font-size: 16px; font-weight: 600; cursor: pointer; transition: opacity 0.15s; font-family: inherit; }
.btn:hover { opacity: 0.85; }
.btn:disabled { opacity: 0.4; cursor: not-allowed; }

.disclaimer { font-size: 11px; color: #bbb; text-align: center; margin-top: 10px; line-height: 1.6; }

.result { margin-top: 2rem; display: none; }

.section { background: #fff; border: 1px solid #e8e8e4; border-radius: 14px; margin-bottom: 10px; overflow: hidden; }
.sec-head { padding: 14px 18px; display: flex; align-items: center; gap: 10px; background: #fafaf8; border-bottom: 1px solid #f0f0ec; }
.badge { font-size: 11px; font-weight: 600; padding: 3px 9px; border-radius: 20px; }
.b-danger { background: #fee; color: #c00; }
.b-warning { background: #fff3e0; color: #e65c00; }
.b-success { background: #e8f5e9; color: #2e7d32; }
.b-info { background: #e3f2fd; color: #1565c0; }
.sec-label { font-size: 14px; font-weight: 600; }
.sec-body { padding: 16px 18px; font-size: 14px; color: #444; line-height: 1.8; white-space: pre-wrap; }

.dots { display: inline-flex; gap: 5px; align-items: center; }
.dot { width: 6px; height: 6px; border-radius: 50%; background: #fff; animation: b 1.2s infinite; }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes b { 0%,80%,100%{transform:translateY(0)} 40%{transform:translateY(-6px)} }
</style>
</head>
<body>
<div class="wrap">
  <div class="logo">CL CONTRACT AI</div>
  <h1>계약서 AI 위험 분석</h1>
  <p class="sub">계약서를 붙여넣으면 위험조항을 자동으로 찾아드립니다</p>

  <div class="card">
    <label>계약서 내용</label>
    <textarea id="txt" placeholder="계약서 전문을 여기에 붙여넣으세요...&#10;&#10;예) 제1조 (목적) 본 계약은..."></textarea>
  </div>

  <div class="card">
    <label>분석 티어</label>
    <div class="tier-row">
      <div class="tier on" onclick="pick(this,'basic')">
        <div class="tier-name">베이직</div>
        <div class="tier-price">9,900원</div>
        <div class="tier-desc">위험조항 탐지 + 핵심 요약</div>
      </div>
      <div class="tier" onclick="pick(this,'standard')">
        <div class="tier-name">스탠다드</div>
        <div class="tier-price">29,000원</div>
        <div class="tier-desc">베이직 + 수정 제안</div>
      </div>
      <div class="tier" onclick="pick(this,'premium')">
        <div class="tier-name">프리미엄</div>
        <div class="tier-price">59,000원</div>
        <div class="tier-desc">스탠다드 + 협상 포인트</div>
      </div>
    </div>

    <button class="btn" id="btn" onclick="go()">분석 시작</button>
    <p class="disclaimer">※ 본 서비스는 AI 참고자료이며 법률 자문이 아닙니다. 중요한 계약은 전문가와 상담하세요.</p>
  </div>

  <div class="result" id="result"></div>
</div>

<script>
let tier = 'basic';
function pick(el, t) {
  document.querySelectorAll('.tier').forEach(c => c.classList.remove('on'));
  el.classList.add('on');
  tier = t;
}

async function go() {
  const txt = document.getElementById('txt').value.trim();
  const btn = document.getElementById('btn');
  if (!txt) { alert('계약서 내용을 입력해주세요.'); return; }

  btn.disabled = true;
  btn.innerHTML = '<span class="dots"><span class="dot"></span><span class="dot"></span><span class="dot"></span></span>';
  document.getElementById('result').style.display = 'none';

  try {
    const res = await fetch('/analyze', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ text: txt, tier })
    });
    const data = await res.json();
    if (data.error) throw new Error(data.error);
    render(data);
  } catch(e) {
    alert('오류: ' + e.message);
  } finally {
    btn.disabled = false;
    btn.innerHTML = '분석 시작';
  }
}

function render(d) {
  let h = '';
  h += sec('b-info', '요약', '계약서 개요', d.summary);
  (d.risks||[]).forEach(r => {
    const bc = r.level==='high'?'b-danger':r.level==='medium'?'b-warning':'b-success';
    const bl = r.level==='high'?'위험 높음':r.level==='medium'?'주의':'낮음';
    h += sec(bc, bl, r.title, r.detail);
  });
  if (d.keyPoints) h += sec('b-info', '핵심', '주요 포인트', d.keyPoints.map((p,i)=>`${i+1}. ${p}`).join('\n'));
  if (d.suggestions) h += sec('b-warning', '제안', '수정 제안', d.suggestions.map((s,i)=>`${i+1}. ${s}`).join('\n'));
  if (d.negotiation) h += sec('b-success', '협상', '협상 포인트', d.negotiation.map((n,i)=>`${i+1}. ${n}`).join('\n'));

  const el = document.getElementById('result');
  el.innerHTML = h;
  el.style.display = 'block';
  el.scrollIntoView({ behavior: 'smooth' });
}

function sec(badge, blabel, title, body) {
  return `<div class="section">
    <div class="sec-head"><span class="badge ${badge}">${blabel}</span><span class="sec-label">${title}</span></div>
    <div class="sec-body">${body}</div>
  </div>`;
}
</script>
</body>
</html>
